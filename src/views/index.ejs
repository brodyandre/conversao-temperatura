<!doctype html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Conversor de temperatura entre Celsius, Fahrenheit e Kelvin.">
    <title><%= appName %></title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <main class="page">
        <header class="hero" aria-labelledby="page-title">
            <div class="brand-row">
                <span class="eyebrow">Conversão rápida</span>
                <span class="env-pill"><%= appEnv %></span>
            </div>
            <h1 id="page-title"><%= appName %></h1>
            <p class="subtitle">Transforme Celsius, Fahrenheit e Kelvin em segundos, com histórico para acompanhar cada cálculo.</p>
        </header>

        <section class="dashboard" aria-label="Conversor de temperatura">
            <div class="conversion-area">
                <form class="converter-card" action="/" method="post">
                    <div class="form-header">
                        <span>Nova conversão</span>
                        <strong>Temperatura</strong>
                    </div>

                    <div class="field-group">
                        <label for="value">Valor</label>
                        <input
                            id="value"
                            name="value"
                            type="number"
                            step="any"
                            inputmode="decimal"
                            placeholder="Ex.: 25"
                            value="<%= form.value %>"
                            required
                        >
                    </div>

                    <div class="field-row">
                        <div class="field-group">
                            <label for="from">De</label>
                            <select id="from" name="from">
                                <% units.forEach((unit) => { %>
                                    <option value="<%= unit.value %>" <%= form.from === unit.value ? 'selected' : '' %>>
                                        <%= unit.label %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="field-group">
                            <label for="to">Para</label>
                            <select id="to" name="to">
                                <% units.forEach((unit) => { %>
                                    <option value="<%= unit.value %>" <%= form.to === unit.value ? 'selected' : '' %>>
                                        <%= unit.label %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <button type="submit">Converter agora</button>

                    <% if (error) { %>
                        <p class="message error" role="alert"><%= error %></p>
                    <% } %>
                </form>

                <section class="result-card" aria-live="polite">
                    <span class="card-kicker">Resultado</span>
                    <% if (result) { %>
                        <strong><%= result.outputValue %> <%= result.outputSymbol %></strong>
                        <p>
                            <%= result.inputValue %> <%= result.inputSymbol %>
                            em <%= result.outputLabel %>
                        </p>
                    <% } else { %>
                        <strong>Pronto para converter</strong>
                        <p>Informe um valor e escolha as unidades.</p>
                    <% } %>
                </section>
            </div>

            <aside class="history-card" aria-labelledby="history-title">
                <div class="history-header">
                    <div>
                        <span class="card-kicker">Histórico</span>
                        <h2 id="history-title">Últimas conversões</h2>
                    </div>
                    <span class="counter"><%= history.length %>/<%= maxHistoryItems %></span>
                </div>

                <% if (history.length) { %>
                    <ol class="history-list">
                        <% history.forEach((item) => { %>
                            <li>
                                <span class="history-time"><%= item.createdAt %></span>
                                <strong>
                                    <%= item.inputValue %> <%= item.inputSymbol %>
                                    para <%= item.outputValue %> <%= item.outputSymbol %>
                                </strong>
                                <small><%= item.inputLabel %> para <%= item.outputLabel %></small>
                            </li>
                        <% }) %>
                    </ol>
                <% } else { %>
                    <p class="empty">Suas conversões recentes aparecem aqui.</p>
                <% } %>
            </aside>
        </section>

        <footer class="footer">
            <span>Aplicação: <strong><%= appName %></strong></span>
            <span>Ambiente: <strong><%= appEnv %></strong></span>
            <span>Host: <strong><%= machine %></strong></span>
        </footer>
    </main>
</body>

</html>
